#!/bin/bash -e

# Diagnostic: the v63 outage (#204 postmortem) came from an entrypoint guard
# on "${1}" == "./bin/rails" that never matched under Fly's init, so
# db:prepare silently never ran. Keep the received args visible in boot logs.
echo "docker-entrypoint args: $*"

# Recreate the Solid Queue SQLite schema before any command except the
# release command's own db:prepare run (the release machine has no use for
# a throwaway queue file). The file lives on the machine's ephemeral rootfs,
# and db:prepare can't be trusted with it: this app dumps :sql schemas
# (config/application.rb), so prepare hunts for db/queue_structure.sql and
# silently skips the load when it's missing -- db/queue_schema.rb is what
# Solid Queue actually ships. See lib/tasks/queue_database.rake and the
# #204/#205 postmortems.
if [[ "$*" != *"db:prepare"* ]]; then
  ./bin/rails db:queue:bootstrap
fi

exec "${@}"
