#!/bin/bash -e

# Diagnostic: the v63 outage (#204 postmortem) came from an entrypoint guard
# on "${1}" == "./bin/rails" that never matched under Fly's init, so
# db:prepare silently never ran. Keep the received args visible in boot logs.
echo "docker-entrypoint args: $*"

# Prepare the databases before any command except the release command's own
# db:prepare (which would only repeat it). Unconditional on purpose -- see
# above for what guessing at the argv shape cost. The Solid Queue SQLite file
# (config/database.yml) lives on the machine's ephemeral rootfs and must be
# recreated from db/queue_schema.rb on every boot; the Neon primary/cache
# databases are prepared idempotently in the same pass, exactly as the
# release command already does on every deploy.
if [[ "$*" != *"db:prepare"* ]]; then
  ./bin/rails db:prepare
fi

exec "${@}"
