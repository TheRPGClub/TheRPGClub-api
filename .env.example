# Rails
RAILS_ENV=development
RAILS_MAX_THREADS=5

# Local PostgreSQL development database
RPGCLUB_DATABASE_NAME=rpgclub_api_development
RPGCLUB_DATABASE_USERNAME=admin
RPGCLUB_DATABASE_PASSWORD=change_me
RPGCLUB_DATABASE_HOST=127.0.0.1
RPGCLUB_DATABASE_PORT=5432

# Neon/production. When present, Rails merges this over ALL environments — including
# test. dotenv loads `.env` in the test env too, so a DATABASE_URL set HERE makes
# `bin/rails db:test:prepare` purge/recreate whatever this URL points at (e.g. your
# production Neon DB) instead of the local test database. Put it in `.env.local`
# instead — dotenv does NOT load `.env.local` in the test environment, so it stays
# active for development while leaving the test suite pointed at the local DB.
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# API auth for service clients such as the Discord bot.
RPGCLUB_BOT_API_TOKEN=change_me_to_a_long_random_token

# IGDB/Twitch API access for Rails-owned GameDB image metadata refreshes.
IGDB_CLIENT_ID=your_twitch_developer_client_id
IGDB_CLIENT_SECRET=your_twitch_developer_client_secret

# Backblaze B2 Native API access for GameDB image storage.
# The key needs writeFiles, listFiles, and deleteFiles for the image bucket.
BACKBLAZE_KEY_ID=your_backblaze_key_id
BACKBLAZE_APPLICATION_KEY=your_backblaze_application_key
BACKBLAZE_BUCKET_ID=your_backblaze_bucket_id
BACKBLAZE_PUBLIC_BASE_URL=https://f000.backblazeb2.com/file/your_bucket_name

# Browser auth through Discord OAuth.
DISCORD_CLIENT_ID=your_numeric_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
DISCORD_OAUTH_SUCCESS_REDIRECT=http://localhost:3001
DISCORD_OAUTH_SCOPES=identify email guilds
DISCORD_RPGCLUB_GUILD_ID=your_rpgclub_discord_server_id

# Next.js/frontend CORS.
RPGCLUB_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Cookie session settings. Use none/true behind HTTPS in production.
RPGCLUB_SESSION_SAME_SITE=lax
RPGCLUB_SESSION_SECURE=false

# Hostnames advertised in the generated OpenAPI spec (Swagger UI at /api-docs).
# These only affect documentation, not runtime routing.
SWAGGER_API_HOST_DEV=http://localhost:3000
SWAGGER_API_HOST_PROD=https://api.example.com
